# name: test/sql/ignore_errors.test
# description: Test ignore_errors parameter for robust batch processing
# group: [sql]

require duck_hunt

# Test ignore_errors with a valid file
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json');
----
4

# Test ignore_errors=true returns same results for valid files
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', ignore_errors := true);
----
4

# Test ignore_errors=false (explicit default)
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', ignore_errors := false);
----
4

# Test combined with severity_threshold and ignore_errors
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', ignore_errors := true, severity_threshold := 'error');
----
1

# Test ignore_errors on workflow log function (parameter accepted)
query I
SELECT COUNT(*) FROM read_duck_hunt_workflow_log('test/sample_github_actions.log', 'github_actions', ignore_errors := true);
----
11

# Test parse_duck_hunt_log also accepts ignore_errors (for API consistency)
query I
SELECT COUNT(*) FROM parse_duck_hunt_log('{"tests":[{"nodeid":"test_pass","outcome":"passed"}]}', 'pytest_json', ignore_errors := true);
----
1

# Test ignore_errors=true on a non-existent file returns empty
query I
SELECT COUNT(*) FROM read_duck_hunt_log('nonexistent_file_12345.json', 'eslint_json', ignore_errors := true);
----
0
