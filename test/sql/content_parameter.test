# name: test/sql/content_parameter.test
# description: Test content parameter for log_content truncation
# group: [sql]

require duck_hunt

# Test that content parameter is accepted with integer value
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 100);
----
4

# Test that content parameter is accepted with string 'full'
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 'full');
----
4

# Test that content parameter is accepted with string 'none'
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 'none');
----
4

# Test that content parameter is accepted with string 'smart'
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 'smart');
----
4

# Test that content := 0 is accepted (same as 'none')
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 0);
----
4

# Test content with parse_duck_hunt_log
query I
SELECT COUNT(*) FROM parse_duck_hunt_log('{"tests":[{"nodeid":"test_pass","outcome":"passed"}]}', 'pytest_json', content := 50);
----
1

# Test content with severity_threshold combined
query I
SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 100, severity_threshold := 'error');
----
1

# Test invalid content mode throws error
statement error
SELECT * FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 'invalid_mode');
----
Invalid content mode

# Test that content := 'none' and content := 'full' are accepted without error
query II
SELECT
  (SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 'none')),
  (SELECT COUNT(*) FROM read_duck_hunt_log('workspace/eslint_sample.json', 'eslint_json', content := 'full'));
----
4	4
